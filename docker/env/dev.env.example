ORACLE_IMAGE=gvenzl/oracle-free:23-slim
ORACLE_PORT=1521
ORACLE_SYS_PASSWORD=oracle
ORACLE_VOLUME=grcpc_dev_oradata

DB_URL=jdbc:oracle:thin:@//localhost:1521/FREEPDB1
DB_USERNAME=GRCPC
DB_PASSWORD=grcpc
DB_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
DB_SCHEMA=GRCPC

MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATA_DIR=/var/lib/minio/data
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_VOLUME=grcpc_dev_minio

