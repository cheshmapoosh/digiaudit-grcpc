# GRCPC portable test environment
# Used by grcpc-app.bat and compose.test-jar.yml

# Docker images
JAVA_IMAGE=eclipse-temurin:21-jre-noble
ORACLE_IMAGE=gvenzl/oracle-free:23-slim
MINIO_IMAGE=minio/minio:latest

# Published ports on Windows host
APP_PORT=8080
ORACLE_PORT=1521
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Oracle test database
ORACLE_SYS_PASSWORD=oracle
DB_URL=jdbc:oracle:thin:@//oracle:1521/FREEPDB1
DB_USERNAME=GRCPC
DB_PASSWORD=grcpc
DB_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
DB_SCHEMA=GRCPC
FLYWAY_ENABLED=true

# MinIO test storage
MINIO_DATA_DIR=/var/lib/minio/data
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=grcpc-documents
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Docker volumes
ORACLE_VOLUME=grcpc_test_oradata
MINIO_VOLUME=grcpc_test_minio
APP_LOG_VOLUME=grcpc_test_app_logs

# Java and logging
JAVA_OPTS=-Xms256m -Xmx512m
ROOT_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
