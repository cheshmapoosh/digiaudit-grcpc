GRCPC_APP_IMAGE=grcpc-app:latest
APP_PORT=8080

DB_URL=jdbc:oracle:thin:@//oracle-host.example.com:1521/ORCLPDB1
DB_USERNAME=GRCPC
DB_PASSWORD=change-me
DB_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
DB_SCHEMA=GRCPC

MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATA_DIR=/var/lib/minio/data
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=grcpc-documents
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://files.example.com
MINIO_VOLUME=grcpc_prod_minio

JAVA_OPTS=-Xms512m -Xmx1024m
